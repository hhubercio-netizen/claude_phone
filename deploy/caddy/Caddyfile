{
    # Cloudflare handles edge TLS; Caddy still serves local HTTPS or
    # plain HTTP behind Cloudflare's tunnel/origin.
    auto_https off
    admin off
}

claude-phone.pl:443 {
    # TM-TLS.1 — lock the version to 1.3. Modern browsers (Chrome >= 70,
    # Firefox >= 63, Safari >= 12.1, Edge >= 79) all negotiate 1.3; 1.2 is
    # only useful for IE 11 / Android < 5, neither of which we target.
    tls /etc/caddy/cert.pem /etc/caddy/key.pem {
        protocols tls1.3
    }

    # API endpoints — WebSocket upgrades, pass-through to gateway
    @websocket {
        header Connection *Upgrade*
        header Upgrade websocket
    }

    reverse_proxy /api/wrapper @websocket {
        to 127.0.0.1:8080
        flush_interval -1
    }

    reverse_proxy /api/phone/* @websocket {
        to 127.0.0.1:8080
        flush_interval -1
    }

    # Static SPA + healthcheck
    reverse_proxy /healthz 127.0.0.1:8080
    reverse_proxy /assets/* 127.0.0.1:8080
    reverse_proxy /s/* 127.0.0.1:8080
    reverse_proxy / 127.0.0.1:8080

    encode gzip zstd

    header {
        # TM-TLS.2 — align with gateway http.rs (2 years + preload). Browsers
        # cache the highest HSTS policy seen, so any layer advertising a
        # weaker value silently weakens defense-in-depth.
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Referrer-Policy "no-referrer"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Permissions-Policy "interest-cohort=()"
    }
}
